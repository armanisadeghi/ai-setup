# =============================================================================
# defaults.env — Default configuration values (committed to git)
#
# These are the shared defaults for all servers.
# To override on a specific server, create config.local.env alongside this file
# (it's gitignored). Any variable set there takes priority.
#
# Secrets (AWS keys, HF tokens, etc.) go in .env_secrets on the server.
# See config/resolve-config.sh for the full resolution order.
# =============================================================================

# --- Paths (auto-detected by resolve-config.sh if not set) ---
# WORKSPACE=          # e.g. /workspace, /home/user/workspace — auto-detected
# COMFYUI_DIR=        # e.g. $WORKSPACE/ComfyUI — auto-detected
# VENV=               # e.g. $WORKSPACE/.venv, /venv/main — auto-detected
# REPO_DIR=           # e.g. /home/user/ai-setup — auto-detected

# --- Git identity ---
GIT_USER_NAME="Arman Isadeghi"
GIT_USER_EMAIL="arman@armansadeghi.com"

# --- ComfyUI settings ---
COMFYUI_PORT=8188
COMFYUI_ARGS="--listen 0.0.0.0 --disable-auto-launch --enable-cors-header"

# --- S3 persistence ---
AWS_BUCKET_MODELS="${AWS_BUCKET_MODELS:-matrx-models}"
AWS_REGION="${AWS_REGION:-us-east-2}"
S3_MODELS_PREFIX="comfyui-models"
S3_OUTPUTS_PREFIX="comfyui-outputs"
S3_WORKFLOWS_PREFIX="comfyui-workflows"
S3_CONFIG_PREFIX="config"

# --- S3 filesystem mount (s3fs) ---
S3_MOUNT_MODELS=/mnt/s3-models
S3_MOUNT_CACHE=/tmp/s3fs-cache

# --- PyTorch install (used when creating venv from scratch) ---
# Auto-detected by resolve-config.sh based on CUDA version
# PYTORCH_INDEX_URL=
